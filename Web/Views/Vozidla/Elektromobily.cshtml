@model List<HlidacStatu.RegistrVozidel.Models.EvTrendItem>
@using System.Globalization
@{
    ViewBag.Title = "Elektromobily a hybridy";
    ViewBag.SubTitle = "Registr vozidel";
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlídač Státu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Elektromobily a hybridy</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-bolt me-2"></i>Vývoj registrací elektrických a hybridních vozidel
</h3>
<p class="text-muted">Počty nově registrovaných elektrických a hybridních osobních automobilů od roku 2010.</p>

<form method="get" class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="statniOnly" value="true" id="statniOnly"
               @(((bool?)ViewBag.StatniOnly == true) ? "checked" : "") onchange="this.form.submit()" />
        <label class="form-check-label" for="statniOnly">Pouze státní organizace</label>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">Žádná data.</div>
}
else
{
    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Rok</th>
                    <th class="text-end">Elektrická</th>
                    <th class="text-end">Hybridní</th>
                    <th class="text-end">EV + hybrid celkem</th>
                    <th class="text-end">Vše celkem</th>
                    <th class="text-end">Podíl EV</th>
                    <th class="text-end">Podíl hybrid</th>
                    <th style="min-width:200px">EV podíl</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    double evPercent = item.TotalCount > 0 ? (double)item.ElectricCount / item.TotalCount * 100 : 0;
                    double hybridPercent = item.TotalCount > 0 ? (double)item.HybridCount / item.TotalCount * 100 : 0;
                    double combinedPercent = evPercent + hybridPercent;

                    <tr>
                        <td><strong>@item.Year</strong></td>
                        <td class="text-end">@item.ElectricCount.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</td>
                        <td class="text-end">@item.HybridCount.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</td>
                        <td class="text-end"><strong>@((item.ElectricCount + item.HybridCount).ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")))</strong></td>
                        <td class="text-end">@item.TotalCount.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</td>
                        <td class="text-end">@evPercent.ToString("N2", CultureInfo.GetCultureInfo("cs-CZ")) %</td>
                        <td class="text-end">@hybridPercent.ToString("N2", CultureInfo.GetCultureInfo("cs-CZ")) %</td>
                        <td>
                            <div class="progress" style="height: 1.2rem;">
                                <div class="progress-bar bg-success" role="progressbar"
                                     style="width: @(Math.Min(evPercent * 2, 100).ToString("F1", CultureInfo.InvariantCulture))%"
                                     title="Elektrická: @evPercent.ToString("F2")%">
                                    @if (evPercent > 2)
                                    {
                                        @($"{evPercent:F1}%")
                                    }
                                </div>
                                <div class="progress-bar bg-info" role="progressbar"
                                     style="width: @(Math.Min(hybridPercent * 2, 100).ToString("F1", CultureInfo.InvariantCulture))%"
                                     title="Hybridní: @hybridPercent.ToString("F2")%">
                                    @if (hybridPercent > 2)
                                    {
                                        @($"{hybridPercent:F1}%")
                                    }
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-2 small text-muted">
        <span class="badge bg-success">Elektrická</span>
        <span class="badge bg-info">Hybridní</span>
        <span class="ms-2">(Sloupcový graf je 2x zvětšený pro lepší čitelnost)</span>
    </div>
}
