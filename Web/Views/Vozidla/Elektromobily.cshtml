@model List<HlidacStatu.Web.Models.EvTrendItem>
@using System.Globalization
@{
    ViewBag.Title = "Elektromobily a hybridy";
    ViewBag.SubTitle = "Registr vozidel";
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlidac Statu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Elektromobily a hybridy</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-bolt me-2"></i>Vyvoj registraci elektrickych a hybridnich vozidel
</h3>
<p class="text-muted">Pocty nove registrovanych elektrickych a hybridnich osobnich automobilu od roku 2010.</p>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">Zadna data.</div>
}
else
{
    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Rok</th>
                    <th class="text-end">Elektricka</th>
                    <th class="text-end">Hybridni</th>
                    <th class="text-end">EV + hybrid celkem</th>
                    <th class="text-end">Vse celkem</th>
                    <th class="text-end">Podil EV</th>
                    <th class="text-end">Podil hybrid</th>
                    <th style="min-width:200px">EV podil</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    double evPercent = item.TotalCount > 0 ? (double)item.ElectricCount / item.TotalCount * 100 : 0;
                    double hybridPercent = item.TotalCount > 0 ? (double)item.HybridCount / item.TotalCount * 100 : 0;
                    double combinedPercent = evPercent + hybridPercent;

                    <tr>
                        <td><strong>@item.Year</strong></td>
                        <td class="text-end">@item.ElectricCount.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</td>
                        <td class="text-end">@item.HybridCount.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</td>
                        <td class="text-end"><strong>@((item.ElectricCount + item.HybridCount).ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")))</strong></td>
                        <td class="text-end">@item.TotalCount.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</td>
                        <td class="text-end">@evPercent.ToString("N2", CultureInfo.GetCultureInfo("cs-CZ")) %</td>
                        <td class="text-end">@hybridPercent.ToString("N2", CultureInfo.GetCultureInfo("cs-CZ")) %</td>
                        <td>
                            <div class="progress" style="height: 1.2rem;">
                                <div class="progress-bar bg-success" role="progressbar"
                                     style="width: @(Math.Min(evPercent * 2, 100).ToString("F1", CultureInfo.InvariantCulture))%"
                                     title="Elektricka: @evPercent.ToString("F2")%">
                                    @if (evPercent > 2)
                                    {
                                        @($"{evPercent:F1}%")
                                    }
                                </div>
                                <div class="progress-bar bg-info" role="progressbar"
                                     style="width: @(Math.Min(hybridPercent * 2, 100).ToString("F1", CultureInfo.InvariantCulture))%"
                                     title="Hybridni: @hybridPercent.ToString("F2")%">
                                    @if (hybridPercent > 2)
                                    {
                                        @($"{hybridPercent:F1}%")
                                    }
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-2 small text-muted">
        <span class="badge bg-success">Elektricka</span>
        <span class="badge bg-info">Hybridni</span>
        <span class="ms-2">(Sloupcovy graf je 2x zvetseny pro lepsi citelnost)</span>
    </div>
}
