@model HlidacStatu.Web.Models.VehicleYearReport
@using System.Globalization
@{
    ViewBag.Title = $"Luxusni auta - {Model.SelectedYear}";
    ViewBag.SubTitle = "Registr vozidel";
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlidac Statu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Luxusni auta</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-gem me-2"></i>Top 50 luxusnich aut registrovanych v roce @Model.SelectedYear
</h3>
<p class="text-muted">
    Auta z rady prednich luxusnich znacek (Rolls-Royce, Bentley, Ferrari, Lamborghini, Bugatti, Porsche, Maserati,
    Aston Martin, McLaren, Tesla, Jaguar, Lexus a dalsi) serazena podle vykonu.
</p>

<form method="get" class="d-inline-block mb-3">
    <label for="rok" class="form-label me-2">Rok registrace:</label>
    <select name="rok" id="rok" class="form-select d-inline-block w-auto" onchange="this.form.submit()">
        @foreach (var y in Model.AvailableYears)
        {
            if (y == Model.SelectedYear)
            {
                <option value="@y" selected="selected">@y</option>
            }
            else
            {
                <option value="@y">@y</option>
            }
        }
    </select>
</form>

@if (!Model.Items.Any())
{
    <div class="alert alert-info mt-3">Zadna data pro rok @Model.SelectedYear.</div>
}
else
{
    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th></th>
                    <th>Znacka</th>
                    <th>Model</th>
                    <th class="text-end">Vykon (kW)</th>
                    <th class="text-end">Vykon (k)</th>
                    <th class="text-end">Max. rychlost</th>
                    <th>Palivo</th>
                    <th>Objem</th>
                    <th>Barva</th>
                    <th>Registrace</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@rank</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.LogoSlug))
                            {
                                <img src="https://somedata.hlidacstatu.cz/v/optimized/@(item.LogoSlug).png"
                                     style="max-height:2rem;max-width:3rem" alt="@item.Brand" />
                            }
                        </td>
                        <td><strong>@Display(item.Brand)</strong></td>
                        <td>@Display(item.Model)</td>
                        <td class="text-end"><strong>@DisplayDecimal(item.PowerKw)</strong></td>
                        <td class="text-end">@DisplayHp(item.PowerKw)</td>
                        <td class="text-end">@DisplayDecimal(item.TopSpeedKmh) km/h</td>
                        <td>@Display(item.Fuel)</td>
                        <td>@Display(item.EngineDisplacement)</td>
                        <td>@Display(item.Color)</td>
                        <td>@DisplayDate(item.RegistrationDate)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.VIN))
                            {
                                <a href="/vozidla/VIN?id=@item.VIN" class="btn btn-sm btn-outline-secondary"
                                   title="Detail vozidla">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </a>
                            }
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string Display(string value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayDecimal(decimal? value)
        => value.HasValue ? value.Value.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")) : "-";

    private static string DisplayHp(decimal? kw)
        => kw.HasValue ? Math.Round(kw.Value * 1.35962m, 0).ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")) : "-";

    private static string DisplayDate(DateTime? value)
        => value.HasValue ? value.Value.ToString("d.M.yyyy", CultureInfo.InvariantCulture) : "-";
}
