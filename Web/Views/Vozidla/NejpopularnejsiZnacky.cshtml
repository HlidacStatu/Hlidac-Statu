@model HlidacStatu.Web.Models.BrandYearReport
@using System.Globalization
@{
    ViewBag.Title = $"Nejpopularnejsi znacky - {Model.SelectedYear}";
    ViewBag.SubTitle = "Registr vozidel";
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlidac Statu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Nejpopularnejsi znacky</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-ranking-star me-2"></i>Nejpopularnejsi automobilove znacky v roce @Model.SelectedYear
</h3>
<p class="text-muted">Top 50 znacek podle poctu nove registrovanych osobnich automobilu.</p>

<form method="get" class="d-inline-block mb-3">
    <label for="rok" class="form-label me-2">Rok registrace:</label>
    <select name="rok" id="rok" class="form-select d-inline-block w-auto" onchange="this.form.submit()">
        @foreach (var y in Model.AvailableYears)
        {
            if (y == Model.SelectedYear)
            {
                <option value="@y" selected="selected">@y</option>
            }
            else
            {
                <option value="@y">@y</option>
            }
        }
    </select>
</form>

@if (!Model.Items.Any())
{
    <div class="alert alert-info mt-3">Zadna data pro rok @Model.SelectedYear.</div>
}
else
{
    int totalRegistrations = Model.Items.Sum(i => i.Count);
    <p class="mb-3"><strong>Celkem registraci:</strong> @totalRegistrations.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</p>

    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th></th>
                    <th>Znacka</th>
                    <th class="text-end">Pocet registraci</th>
                    <th class="text-end">Podil</th>
                    <th style="min-width:200px"></th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model.Items)
                {
                    double percent = totalRegistrations > 0 ? (double)item.Count / totalRegistrations * 100 : 0;
                    <tr>
                        <td>@rank</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.LogoSlug))
                            {
                                <img src="https://somedata.hlidacstatu.cz/v/optimized/@(item.LogoSlug).png"
                                     style="max-height:2rem;max-width:3rem" alt="@item.Brand" />
                            }
                        </td>
                        <td><strong>@(string.IsNullOrWhiteSpace(item.Brand) ? "-" : item.Brand)</strong></td>
                        <td class="text-end"><strong>@item.Count.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</strong></td>
                        <td class="text-end">@percent.ToString("N1", CultureInfo.GetCultureInfo("cs-CZ")) %</td>
                        <td>
                            <div class="progress" style="height: 1.2rem;">
                                <div class="progress-bar bg-primary" role="progressbar"
                                     style="width: @percent.ToString("F1", CultureInfo.InvariantCulture)%"
                                     aria-valuenow="@percent.ToString("F1", CultureInfo.InvariantCulture)"
                                     aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}
