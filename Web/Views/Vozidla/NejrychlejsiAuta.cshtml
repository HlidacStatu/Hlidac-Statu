@model HlidacStatu.RegistrVozidel.Models.VehicleYearReport
@using System.Globalization
@{
    ViewBag.Title = $"50 nejrychlejsich aut" + (Model.SelectedYear.HasValue ? $" - {Model.SelectedYear}" : "");
    ViewBag.SubTitle = "Registr vozidel";
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlidac Statu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Nejrychlejsi auta</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-rocket me-2"></i>50 nejrychlejsich aut @(Model.SelectedYear.HasValue ? $"registrovanych v roce {Model.SelectedYear}" : "za vsechny roky")
</h3>
<p class="text-muted">Osobni automobily serazene podle maximalni rychlosti (km/h).</p>

<form method="get" class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <div class="d-flex align-items-center gap-2">
        <label for="rok" class="form-label mb-0">Rok registrace:</label>
        <select name="rok" id="rok" class="form-select d-inline-block w-auto" onchange="this.form.submit()">
            <option value="">Vsechny roky</option>
            @foreach (var y in Model.AvailableYears)
            {
                if (y == Model.SelectedYear)
                {
                    <option value="@y" selected="selected">@y</option>
                }
                else
                {
                    <option value="@y">@y</option>
                }
            }
        </select>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="statniOnly" value="true" id="statniOnly"
               @(((bool?)ViewBag.StatniOnly == true) ? "checked" : "") onchange="this.form.submit()" />
        <label class="form-check-label" for="statniOnly">Pouze statni organizace</label>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="alert alert-info mt-3">Zadna data @(Model.SelectedYear.HasValue ? $"pro rok {Model.SelectedYear}" : "").</div>
}
else
{
    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th></th>
                    <th>Znacka</th>
                    <th>Model</th>
                    <th class="text-end">Max. rychlost (km/h)</th>
                    <th class="text-end">Vykon (kW)</th>
                    <th class="text-end">Vykon (k)</th>
                    <th>Palivo</th>
                    <th>Objem</th>
                    <th>Barva</th>
                    <th>Registrace</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@rank</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.Logoslug))
                            {
                                <img src="https://somedata.hlidacstatu.cz/v/optimized/@(item.Logoslug).png"
                                     style="max-height:2rem;max-width:3rem" alt="@item.Tovarni_znacka" />
                            }
                        </td>
                        <td><strong>@Display(item.Tovarni_znacka)</strong></td>
                        <td>@Display(item.Model)</td>
                        <td class="text-end"><strong>@DisplayDecimal(item.Nejvyssi_rychlost)</strong></td>
                        <td class="text-end">@DisplayDecimal(item.Max_vykon)</td>
                        <td class="text-end">@DisplayHp(item.Max_vykon)</td>
                        <td>@Display(item.Palivo)</td>
                        <td>@Display(item.Zdvihovy_objem)</td>
                        <td>@Display(item.Barva)</td>
                        <td>@DisplayDate(item.Datum_1_registrace_v_CR)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.VIN))
                            {
                                <a href="/vozidla/VIN?id=@item.VIN" class="btn btn-sm btn-outline-secondary"
                                   title="Detail vozidla">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </a>
                            }
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string Display(string value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayDecimal(decimal? value)
        => value.HasValue ? value.Value.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")) : "-";

    private static string DisplayHp(decimal? kw)
        => kw.HasValue ? Math.Round(kw.Value * 1.35962m, 0).ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")) : "-";

    private static string DisplayDate(DateOnly? value)
        => value.HasValue ? value.Value.ToString("d.M.yyyy", CultureInfo.InvariantCulture) : "-";
}
