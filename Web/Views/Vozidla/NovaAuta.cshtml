@model IEnumerable<Tuple<string, int, Dictionary<string, int>>>
@using System.Globalization
@{
    ViewBag.Title = "Nově registrovaná auta u státních organizací";
    ViewBag.SubTitle = "Registr vozidel";
    bool statniOnly = (bool?)ViewBag.StatniOnly == true;
    int mesice = (ViewBag.Mesice as int?) ?? 12;

    string zaMesice = Devmasters.Lang.CS.Plural.Get(mesice, "za poslední měsíc", "za poslední {0} měsíce", "za posledních {0} měsíců");
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlídač Státu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">@ViewBag.Title</li>
    </ol>
}

<div class="my-4">
    <span>za poslední 
        <a class="btn btn-hs btn-sm @(mesice == 1 ? "btn-secondary" : "btn-outline-primary") mx-2" href="novaauta?mesice=3">měsíc</a>
        <a class="btn btn-hs btn-sm @(mesice == 3 ? "btn-secondary" : "btn-outline-primary") mx-2" href="novaauta?mesice=3">3 měsíce</a>
        <a class="btn btn-hs btn-sm @(mesice == 6 ? "btn-secondary" : "btn-outline-primary") mx-2" href="novaauta?mesice=6">6 měsíců</a>
        <a class="btn btn-hs btn-sm @(mesice == 12 ? "btn-secondary" : "btn-outline-primary") mx-2" href="novaauta?mesice=12">1 rok</a>
        
    </span>
    
</div>


<h3 class="mt-2">
    <i class="fa-solid fa-calendar-plus me-2"></i>Nově registrovaná osobní auta @zaMesice.
</h3>
<p class="text-muted">Vozidla prvně registrovaná v ČR.</p>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">Žádná nová registrace @zaMesice.</div>
}
else
{
    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Organizace</th>
                    <th>Počet </th>
                    <th>Značky</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@rank</td>
                        <td><a href="/subjekt/@item.Item1">@(await HlidacStatu.Repositories.Cache.FirmaCache.GetJmenoAsync(item.Item1))</a>
                            </td>
                        <td>@item.Item2</td>
                        <td>
                            @if (item.Item3.Any())
                            {
                                @(string.Join(", ", item.Item3.OrderByDescending(o=>o.Value).Select(s => $"{s.Value}x {s.Key}"))); 
                            }
                        </td>
                        <td>
                                <a href="/subjekt/vozovyparklist/@(item.Item1)?nove=true&mesice=@ViewBag.Mesice" class="btn btn-sm btn-outline-secondary"
                                   title="Detail vozidla">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </a>
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string Display(string value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayDecimal(decimal? value)
        => value.HasValue ? value.Value.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")) : "-";

    private static string DisplayInt(int? value)
        => value.HasValue ? value.Value.ToString() : "-";

    private static string DisplayDate(DateOnly? value)
        => value.HasValue ? value.Value.ToString("d.M.yyyy", CultureInfo.InvariantCulture) : "-";
}
