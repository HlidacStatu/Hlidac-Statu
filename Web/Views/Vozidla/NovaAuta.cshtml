@model List<HlidacStatu.RegistrVozidel.Models.VozidloLightPerIco>
@using System.Globalization
@{
    ViewBag.Title = "Nove registrovana auta";
    ViewBag.SubTitle = "Registr vozidel";
    bool statniOnly = (bool?)ViewBag.StatniOnly == true;
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlidac Statu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Nova auta</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-calendar-plus me-2"></i>Nove registrovana osobni auta za posledni mesic
</h3>
<p class="text-muted">Vozidla prvne registrovana v CR behem poslednich 30 dni.</p>

<form method="get" class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="statniOnly" value="true" id="statniOnly"
               @(statniOnly ? "checked" : "") onchange="this.form.submit()" />
        <label class="form-check-label" for="statniOnly">Pouze statni organizace</label>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">Zadna nova registrace za posledni mesic.</div>
}
else
{
    <p class="mb-3"><strong>Pocet registraci:</strong> @Model.Count</p>
    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th></th>
                    <th>Znacka</th>
                    <th>Model</th>
                    <th class="text-end">Vykon (kW)</th>
                    <th class="text-end">Max. rychlost</th>
                    <th>Palivo</th>
                    <th>Barva</th>
                    <th>Rok vyroby</th>
                    <th>Registrace</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@rank</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.Logoslug))
                            {
                                <img src="https://somedata.hlidacstatu.cz/v/optimized/@(item.Logoslug).png"
                                     style="max-height:2rem;max-width:3rem" alt="@item.Tovarni_znacka" />
                            }
                        </td>
                        <td><strong>@Display(item.Tovarni_znacka)</strong></td>
                        <td>@Display(item.Model)</td>
                        <td class="text-end">@DisplayDecimal(item.Max_vykon)</td>
                        <td class="text-end">@DisplayDecimal(item.Nejvyssi_rychlost) km/h</td>
                        <td>@Display(item.Palivo)</td>
                        <td>@Display(item.Barva)</td>
                        <td>@DisplayInt(item.Rok_vyroby)</td>
                        <td>@DisplayDate(item.Datum_1_registrace_v_CR)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.VIN))
                            {
                                <a href="/vozidla/VIN?id=@item.VIN" class="btn btn-sm btn-outline-secondary"
                                   title="Detail vozidla">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </a>
                            }
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string Display(string value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayDecimal(decimal? value)
        => value.HasValue ? value.Value.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")) : "-";

    private static string DisplayInt(int? value)
        => value.HasValue ? value.Value.ToString() : "-";

    private static string DisplayDate(DateOnly? value)
        => value.HasValue ? value.Value.ToString("d.M.yyyy", CultureInfo.InvariantCulture) : "-";
}
