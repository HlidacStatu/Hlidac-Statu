@model List<HlidacStatu.RegistrVozidel.Models.VozidloLightPerIco>
@using System.Globalization
@{
    ViewBag.Title = "Auta s prošlou STK";
    ViewBag.SubTitle = "Registr vozidel";
    bool statniOnly = (bool?)ViewBag.StatniOnly == true;
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlídač Státu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Propadlá STK</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-triangle-exclamation me-2"></i>Auta s neplatnou technickou prohlídkou
</h3>
<p class="text-muted">Osobní automobily, jejichž poslední technická prohlídka již není platná.</p>

<form method="get" class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="statniOnly" value="true" id="statniOnly"
               @(statniOnly ? "checked" : "") onchange="this.form.submit()" />
        <label class="form-check-label" for="statniOnly">Pouze státní organizace</label>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-success mt-3">Žádná vozidla s prošlou STK nebyla nalezena.</div>
}
else
{
    <p class="mb-3"><strong>Zobrazeno:</strong> @Model.Count vozidel</p>
    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th></th>
                    <th>Značka</th>
                    <th>Model</th>
                    <th class="text-end">STK platná do</th>
                    <th class="text-end">Prošlých dní</th>
                    <th class="text-end">Výkon (kW)</th>
                    <th>Palivo</th>
                    <th>Rok výroby</th>
                    <th>Registrace</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model)
                {
                    int? daysExpired = item.PlastnostStk.HasValue
                        ? DateOnly.FromDateTime(DateTime.Today).DayNumber - item.PlastnostStk.Value.DayNumber
                        : null;

                    string rowClass = daysExpired switch
                    {
                        > 365 => "table-danger",
                        > 90 => "table-warning",
                        _ => ""
                    };

                    <tr class="@rowClass">
                        <td>@rank</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.Logoslug))
                            {
                                <img src="https://somedata.hlidacstatu.cz/v/optimized/@(item.Logoslug).png"
                                     style="max-height:2rem;max-width:3rem" alt="@item.Tovarni_znacka" />
                            }
                        </td>
                        <td><strong>@Display(item.Tovarni_znacka)</strong></td>
                        <td>@Display(item.Model)</td>
                        <td class="text-end"><strong>@DisplayDate(item.PlastnostStk)</strong></td>
                        <td class="text-end">
                            @if (daysExpired.HasValue)
                            {
                                <span class="badge bg-@(daysExpired > 365 ? "danger" : daysExpired > 90 ? "warning" : "secondary")">
                                    @daysExpired dní
                                </span>
                            }
                        </td>
                        <td class="text-end">@DisplayDecimal(item.Max_vykon)</td>
                        <td>@Display(item.Palivo)</td>
                        <td>@DisplayInt(item.Rok_vyroby)</td>
                        <td>@DisplayDate(item.Datum_1_registrace_v_CR)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.VIN))
                            {
                                <a href="/vozidla/VIN?id=@item.VIN" class="btn btn-sm btn-outline-secondary"
                                   title="Detail vozidla">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </a>
                            }
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string Display(string value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayDecimal(decimal? value)
        => value.HasValue ? value.Value.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ")) : "-";

    private static string DisplayInt(int? value)
        => value.HasValue ? value.Value.ToString() : "-";

    private static string DisplayDate(DateOnly? value)
        => value.HasValue ? value.Value.ToString("d.M.yyyy", CultureInfo.InvariantCulture) : "-";
}
