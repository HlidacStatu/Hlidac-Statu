@model IEnumerable<Tuple<string, int>>
@using System.Globalization
@{
    ViewBag.Title = "Auta s prošlou STK";
    ViewBag.SubTitle = "Registr vozidel";
    bool statniOnly = (bool?)ViewBag.StatniOnly == true;
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlídač Státu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Propadlá STK</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-triangle-exclamation me-2"></i>Úřady provozující auta s propadlou STK
</h3>
<p class="text-muted">Top 100 úřadů, které provozují nebo vlastní neodhlášená auta bez platné STK.</p>

<form method="get" class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="statniOnly" value="true" id="statniOnly"
               @(statniOnly ? "checked" : "") onchange="this.form.submit()" />
        <label class="form-check-label" for="statniOnly">Pouze státní organizace</label>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-success mt-3">Žádná vozidla s prošlou STK nebyla nalezena.</div>
}
else
{
    <p class="mb-3"><strong>Zobrazeno:</strong> @Model.Count() vozidel</p>
    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Firma</th>
                    <th>Počet vozidel bez STK</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model)
                {
                    string companyName = await HlidacStatu.Repositories.Cache.FirmaCache.GetJmenoAsync(item.Item1);
                    <tr>
                        <td>@rank</td>
                        <td>
                            <a href="/subjekty/@item.Item1">@companyName</a>
                        </td>
                        <td>@(HlidacStatu.Util.RenderData.NiceNumber(item.Item2))</td>
                        <td>
                            <a href="/subjekt/VozovyParkList/@item.Item1?bezSTK=true" class="btn btn-sm btn-outline-secondary"
                                title="Seznam vozidel bez STK">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </a>
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}

