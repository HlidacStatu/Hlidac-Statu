@model HlidacStatu.RegistrVozidel.Models.FuelYearReport
@using System.Globalization
@{
    ViewBag.Title = "Rozdělení paliv" + (Model.SelectedYear.HasValue ? $" - {Model.SelectedYear}" : "");
    ViewBag.SubTitle = "Registr vozidel";
    string[] barColors = { "primary", "success", "warning", "info", "danger", "secondary", "dark" };
}

@section breadcrumb
{
    <ol class="breadcrumb">
        <li><a href="/">Hlídač Státu</a></li>
        <li><a href="/vozidla">Registr vozidel</a></li>
        <li><a href="/vozidla/Statistiky">Statistiky</a></li>
        <li class="active">Rozdělení paliv</li>
    </ol>
}

<h3 class="mt-2">
    <i class="fa-solid fa-gas-pump me-2"></i>Rozdělení typu paliv @(Model.SelectedYear.HasValue ? $"v roce {Model.SelectedYear}" : "za všechny roky")
</h3>
<p class="text-muted">Distribuce typu paliv u nově registrovaných osobních automobilů.</p>

<form method="get" class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <div class="d-flex align-items-center gap-2">
        <label for="rok" class="form-label mb-0">Rok registrace:</label>
        <select name="rok" id="rok" class="form-select d-inline-block w-auto" onchange="this.form.submit()">
            <option value="">Všechny roky</option>
            @foreach (var y in Model.AvailableYears)
            {
                if (y == Model.SelectedYear)
                {
                    <option value="@y" selected="selected">@y</option>
                }
                else
                {
                    <option value="@y">@y</option>
                }
            }
        </select>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="alert alert-info mt-3">Žádná data @(Model.SelectedYear.HasValue ? $"pro rok {Model.SelectedYear}" : "").</div>
}
else
{
    <p class="mb-3"><strong>Celkem registrací s údajem o palivu:</strong> @Model.TotalCount.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</p>

    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Typ paliva</th>
                    <th class="text-end">Počet</th>
                    <th class="text-end">Podíl</th>
                    <th style="min-width:250px"></th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model.Items)
                {
                    double percent = Model.TotalCount > 0 ? (double)item.Count / Model.TotalCount * 100 : 0;
                    string color = barColors[(rank - 1) % barColors.Length];

                    <tr>
                        <td>@rank</td>
                        <td><strong>@(string.IsNullOrWhiteSpace(item.FuelType) ? "-" : item.FuelType)</strong></td>
                        <td class="text-end"><strong>@item.Count.ToString("N0", CultureInfo.GetCultureInfo("cs-CZ"))</strong></td>
                        <td class="text-end">@percent.ToString("N1", CultureInfo.GetCultureInfo("cs-CZ")) %</td>
                        <td>
                            <div class="progress" style="height: 1.2rem;">
                                <div class="progress-bar bg-@color" role="progressbar"
                                     style="width: @percent.ToString("F1", CultureInfo.InvariantCulture)%"
                                     aria-valuenow="@percent.ToString("F1", CultureInfo.InvariantCulture)"
                                     aria-valuemin="0" aria-valuemax="100">
                                    @if (percent > 5)
                                    {
                                        @($"{percent:N1} %")
                                    }
                                </div>
                            </div>
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}
